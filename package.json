{
    "name": "cocos-framework-cli",
    "version": "1.0.0",
    "description": "Cocos Creator 框架 CLI 工具 - 一键集成核心框架到项目",
    "main": "dist/index.js",
    "bin": {
        "cocos-framework": "./dist/cli.js"
    },
    "scripts": {
        "build": "tsc",
        "watch": "tsc --watch",
        "prepublishOnly": "npm run build",
        "postinstall": "node scripts/postinstall.js",
        "setup": "node setup.js",
        "ins": "node install.js"
    },
    "keywords": [
        "cocos",
        "cocos-creator",
        "framework",
        "cli",
        "template"
    ],
    "author": "yyd",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/yourname/cocos-framework-cli.git"
    },
    "dependencies": {
        "chalk": "^4.1.2",
        "commander": "^9.4.1",
        "fs-extra": "^10.1.0",
        "inquirer": "^8.2.5"
    },
    "devDependencies": {
        "@types/fs-extra": "^9.0.13",
        "@types/inquirer": "^8.2.5",
        "@types/node": "^18.11.9",
        "typescript": "^4.9.5"
    },
    "files": [
        "dist",
        "scripts",
        "template",
        "README.md"
    ],
    "engines": {
        "node": ">=14.0.0"
    }
}
