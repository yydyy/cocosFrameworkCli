{
    "compilerOptions": {
        "declaration": true,
        "declarationMap": false,
        "downlevelIteration": true,
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "lib": [
            "ES6",
            "es2017",
            "dom"
        ],
        "module": "ESNext",
        "moduleResolution": "node",
        "skipLibCheck": true,
        "sourceMap": true,
        "strict": true,
        "target": "es5"
    },
    "exclude": [
        "node_modules"
    ],
    "include": [
        "src/**/*"
    ]
}